# Quran Corpus Visualizer - Environment Variables
# Copy this file to .env.local and fill in the values

# === Feedback Email (Optional) ===
# Required only for the feedback form email delivery feature
BREVO_API_KEY=your_brevo_api_key_here
FEEDBACK_TO_EMAIL=info@pluragate.org
FEEDBACK_FROM_EMAIL=info@pluragate.org
FEEDBACK_FROM_NAME=Quran Corpus Visualizer

# Fallback (used only if FEEDBACK_TO_EMAIL is not set)
# NEXT_PUBLIC_FEEDBACK_EMAIL=info@pluragate.org
# Supabase — required for all Supabase features
# Find these in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role — used ONLY in server-side scripts (seed, generate-embeddings)
# Never expose this to the browser or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# OpenAI — required for semantic search (/api/search/semantic)
OPENAI_API_KEY=sk-...
